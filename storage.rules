rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /event-images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'organizer' &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }
    match /circle-images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'organizer' &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }
    // avatar-images: 本人のUIDと一致するパスにのみ書き込み可（誰でも自分のアバターは
    // 設定できるべきなので、event/circle画像と違いorganizer判定は不要。
    // パス自体にUIDを含めることで、firestore.get()のcross-service呼び出しを使わずに
    // アクセス制御できる）
    match /avatar-images/{uid}/{imageId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }
  }
}
